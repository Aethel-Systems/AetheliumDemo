        if row == 5 { return 0x06FD0 }
        if row == 6 { return 0x001E0 }
        if row == 7 { return 0x381D0 }
        if row == 8 { return 0x37F80 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    if ch == 84 {
        if row == 0 { return 0x00000 }
        if row == 1 { return 0xBFFF0 }
        if row == 2 { return 0xB2CB0 }
        if row == 3 { return 0x72CB0 }
        if row == 4 { return 0x02C00 }
        if row == 5 { return 0x02C00 }
        if row == 6 { return 0x02C00 }
        if row == 7 { return 0x02C00 }
        if row == 8 { return 0x1FF80 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    if ch == 85 {
        if row == 0 { return 0x00000 }
        if row == 1 { return 0xFF7F4 }
        if row == 2 { return 0x380E0 }
        if row == 3 { return 0x380E0 }
        if row == 4 { return 0x380E0 }
        if row == 5 { return 0x380E0 }
        if row == 6 { return 0x380D0 }
        if row == 7 { return 0x2D2C0 }
        if row == 8 { return 0x0BF40 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    if ch == 86 {
        if row == 0 { return 0x00000 }
        if row == 1 { return 0xFD3F8 }
        if row == 2 { return 0x780E0 }
        if row == 3 { return 0x3C1D0 }
        if row == 4 { return 0x1D3C0 }
        if row == 5 { return 0x0E740 }
        if row == 6 { return 0x0BB00 }
        if row == 7 { return 0x07E00 }
        if row == 8 { return 0x02D00 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    if ch == 87 {
        if row == 0 { return 0x00000 }
        if row == 1 { return 0xFE7F8 }
        if row == 2 { return 0xB00B0 }
        if row == 3 { return 0x73DB0 }
        if row == 4 { return 0x77EE0 }
        if row == 5 { return 0x3FFE0 }
        if row == 6 { return 0x3F7E0 }
        if row == 7 { return 0x3E3D0 }
        if row == 8 { return 0x3C2D0 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    if ch == 88 {
        if row == 0 { return 0x00000 }
        if row == 1 { return 0xBE3F0 }
        if row == 2 { return 0x2D3C0 }
        if row == 3 { return 0x0FB40 }
        if row == 4 { return 0x07E00 }
        if row == 5 { return 0x07E00 }
        if row == 6 { return 0x0FB40 }
        if row == 7 { return 0x2D3D0 }
        if row == 8 { return 0xFE7F4 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    if ch == 89 {
        if row == 0 { return 0x00000 }
        if row == 1 { return 0xBD3F4 }
        if row == 2 { return 0x2D3C0 }
        if row == 3 { return 0x0F740 }
        if row == 4 { return 0x07E00 }
        if row == 5 { return 0x02C00 }
        if row == 6 { return 0x02C00 }
        if row == 7 { return 0x02C00 }
        if row == 8 { return 0x1FFC0 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    if ch == 90 {
        if row == 0 { return 0x00000 }
        if row == 1 { return 0x3FFD0 }
        if row == 2 { return 0x3C7C0 }
        if row == 3 { return 0x28F40 }
        if row == 4 { return 0x02D00 }
        if row == 5 { return 0x07800 }
        if row == 6 { return 0x0F0D0 }
        if row == 7 { return 0x2D0E0 }
        if row == 8 { return 0x3FFE0 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    return 0
}

func glyph/alpha/level(packed: UInt32, col: UInt32) : UInt32 {
    let shift: UInt32 = (GLYPH/WIDTH - 1 - col) * 2
    return (packed >> shift) & 0x3
}

func glyph/alpha/coverage(level: UInt32) : UInt32 {
    if level == 0 {
        return 0
    }
    if level == 1 {
        return 132
    }
    if level == 2 {
        return 224
    }
    return 255
}

func draw/glyph/layer(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, ch: UInt8, color: UInt32, scale: UInt32, alpha/factor: UInt32) {
    let row: UInt32 = 0
    while row < GLYPH/HEIGHT {
        let packed: UInt32 = glyph/alpha/row(ch, row)
        let col: UInt32 = 0
        while col < GLYPH/WIDTH {
            let coverage: UInt32 = glyph/alpha/coverage(glyph/alpha/level(packed, col))
            let alpha: UInt32 = alpha/modulate(coverage, alpha/factor)
            if alpha != 0 {
                let sy: UInt32 = 0
                while sy < scale {
                    let sx: UInt32 = 0
                    while sx < scale {
                        pixel/blend(back, x + (col * scale) + sx, y + (row * scale) + sy, color, alpha)
                        sx = sx + 1
                    }
                    sy = sy + 1
                }
            }
            col = col + 1
        }
        row = row + 1
    }
}

func text/draw/glyph(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, ch: UInt8, style: ptr<AER/TEXT/STYLE>) {
    let halo: UInt32 = 0
    if style\scale > 1 {
        halo = style\scale - 1
    }

    if style\shadow/alpha != 0 {
        draw/glyph/layer(back, x + 1, y + 1, ch, style\shadow/color, style\scale, style\shadow/alpha)
    }
    if style\glow/alpha != 0 {
        if x >= halo {
            draw/glyph/layer(back, x - halo, y, ch, style\glow/color, style\scale, style\glow/alpha)
        }
        draw/glyph/layer(back, x + halo, y, ch, style\glow/color, style\scale, style\glow/alpha)
        if y >= halo {
            draw/glyph/layer(back, x, y - halo, ch, style\glow/color, style\scale, style\glow/alpha)
        }
        draw/glyph/layer(back, x, y + halo, ch, style\glow/color, style\scale, style\glow/alpha)
    }
    if style\scale > 1 {
        draw/glyph/layer(back, x + 1, y, ch, style\color, style\scale, 96)
        draw/glyph/layer(back, x, y + 1, ch, style\color, style\scale, 64)
    }
    draw/glyph/layer(back, x, y, ch, style\color, style\scale, ALPHA/MAX)
}

func text/draw/literal(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, a: UInt8, b: UInt8, c: UInt8, d: UInt8, e: UInt8, f: UInt8, g: UInt8, h: UInt8, i: UInt8, j: UInt8, len: UInt32, style: ptr<AER/TEXT/STYLE>) {
    let advance: UInt32 = text/advance(style)
    if len > 0 { text/draw/glyph(back, x + (0 * advance), y, a, style) }
    if len > 1 { text/draw/glyph(back, x + (1 * advance), y, b, style) }
    if len > 2 { text/draw/glyph(back, x + (2 * advance), y, c, style) }
    if len > 3 { text/draw/glyph(back, x + (3 * advance), y, d, style) }
    if len > 4 { text/draw/glyph(back, x + (4 * advance), y, e, style) }
    if len > 5 { text/draw/glyph(back, x + (5 * advance), y, f, style) }
    if len > 6 { text/draw/glyph(back, x + (6 * advance), y, g, style) }
    if len > 7 { text/draw/glyph(back, x + (7 * advance), y, h, style) }
    if len > 8 { text/draw/glyph(back, x + (8 * advance), y, i, style) }
    if len > 9 { text/draw/glyph(back, x + (9 * advance), y, j, style) }
}

func text/draw/u32(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, min/digits: UInt32, style: ptr<AER/TEXT/STYLE>) {
    let div: UInt32 = DEC/THOUSAND * DEC/TEN
    let started: UInt32 = 0
    let pos: UInt32 = 0
    let advance: UInt32 = text/advance(style)
    while div > 0 {
        let digit: UInt32 = (value / div) % DEC/TEN
        if digit != 0 || started != 0 || div == 1 || min/digits > pos + 1 {
            text/draw/glyph(back, x + (pos * advance), y, cast<UInt8>(48 + digit), style)
            started = 1
            pos = pos + 1
        }
        div = div / DEC/TEN
    }
}

func text/draw/two(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, style: ptr<AER/TEXT/STYLE>) {
    let advance: UInt32 = text/advance(style)
    text/draw/glyph(back, x, y, cast<UInt8>(48 + ((value / DEC/TEN) % DEC/TEN)), style)
    text/draw/glyph(back, x + advance, y, cast<UInt8>(48 + (value % DEC/TEN)), style)
}

func text/draw/four(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, style: ptr<AER/TEXT/STYLE>) {
    let advance: UInt32 = text/advance(style)
    text/draw/glyph(back, x, y, cast<UInt8>(48 + ((value / DEC/THOUSAND) % DEC/TEN)), style)
    text/draw/glyph(back, x + advance, y, cast<UInt8>(48 + ((value / DEC/HUNDRED) % DEC/TEN)), style)
    text/draw/glyph(back, x + (2 * advance), y, cast<UInt8>(48 + ((value / DEC/TEN) % DEC/TEN)), style)
    text/draw/glyph(back, x + (3 * advance), y, cast<UInt8>(48 + (value % DEC/TEN)), style)
}

func draw/glyph(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, ch: UInt8, color: UInt32, scale: UInt32) {
    let style: AER/TEXT/STYLE
    text/style/set(&style as ptr<AER/TEXT/STYLE>, color, color, 0xFF000000, 0, 0, scale, 0)
    text/draw/glyph(back, x, y, ch, &style as ptr<AER/TEXT/STYLE>)
}

func draw/literal(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, a: UInt8, b: UInt8, c: UInt8, d: UInt8, e: UInt8, f: UInt8, g: UInt8, h: UInt8, i: UInt8, j: UInt8, len: UInt32, color: UInt32, scale: UInt32) {
    let style: AER/TEXT/STYLE
    text/style/set(&style as ptr<AER/TEXT/STYLE>, color, color, 0xFF000000, 0, 0, scale, 0)
    text/draw/literal(back, x, y, a, b, c, d, e, f, g, h, i, j, len, &style as ptr<AER/TEXT/STYLE>)
}

func draw/u32(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, min/digits: UInt32, color: UInt32, scale: UInt32) {
    let style: AER/TEXT/STYLE
    text/style/set(&style as ptr<AER/TEXT/STYLE>, color, color, 0xFF000000, 0, 0, scale, 0)
    text/draw/u32(back, x, y, value, min/digits, &style as ptr<AER/TEXT/STYLE>)
}

func draw/two(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, color: UInt32, scale: UInt32) {
    let style: AER/TEXT/STYLE
    text/style/set(&style as ptr<AER/TEXT/STYLE>, color, color, 0xFF000000, 0, 0, scale, 0)
    text/draw/two(back, x, y, value, &style as ptr<AER/TEXT/STYLE>)
}

func draw/four(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, color: UInt32, scale: UInt32) {
    let style: AER/TEXT/STYLE
    text/style/set(&style as ptr<AER/TEXT/STYLE>, color, color, 0xFF000000, 0, 0, scale, 0)
    text/draw/four(back, x, y, value, &style as ptr<AER/TEXT/STYLE>)
}

func shell/layout/init(shell: ptr<AER/SHELL>) {
    let frame/init: AER/RECT
    rect/set(&frame/init as ptr<AER/RECT>, 72, 54, shell\back\width - 144, shell\back\height - 128)
    shell\main/window\frame\x = frame/init\x
    shell\main/window\frame\y = frame/init\y
    shell\main/window\frame\w = frame/init\w
    shell\main/window\frame\h = frame/init\h
    shell\main/window\accent = 0xFF3A6EA5
    shell\main/window\material = 0xFF16202C
    shell\pointer\x = 32
    shell\pointer\y = 32
    shell\pointer\visible = 1
    shell\disk0\state = 1
    shell\disk0\pending/since = 0
    shell\disk0\timeout/ms = 1500
    shell\nexus\revision = 0x01000000
    shell\sensor/cpu/temp = 0
    shell\sensor/cpu/online = 0
}

func shell/update/telemetry(shell: ptr<AER/SHELL>) {
    let sys/table: ptr<EFI/SYSTEM/TABLE> = cast<ptr<EFI/SYSTEM/TABLE>>(shell\sys/table)
    let now: EFI/TIME
    if uefi/get/time(sys/table, &now as ptr<EFI/TIME>) == EFI/SUCCESS {
        shell\clock/year = now\year
        shell\clock/month = now\month
        shell\clock/day = now\day
        shell\clock/hour = now\hour
        shell\clock/minute = now\minute
        shell\clock/second = now\second
    }
    if (shell\ticks & 63) == 0 {
        uefi/query/memory(sys/table, &shell\memory/total/mb as ptr<UInt32>, &shell\memory/used/mb as ptr<UInt32>)
    }
}

func shell/poll/input(shell: ptr<AER/SHELL>) {
    if shell == 0 {
        loop { hardware { hardware\isa\hlt() } }
    }

    let sys/table: ptr<EFI/SYSTEM/TABLE> = cast<ptr<EFI/SYSTEM/TABLE>>(shell\sys/table)
    let key: EFI/INPUT/KEY

    if shell\ticks < shell\exit/armed/after {
        return
    }

    let st: UInt64 = uefi/read/key(sys/table, &key as ptr<EFI/INPUT/KEY>)

    if st == EFI/SUCCESS {
        if key\unicode/char == 27 || key\scan/code == 23 {
            if shell\ticks - shell\last/esc/ticks < 80 {
                shell\exit/requested = 1
            }
            shell\last/esc/ticks = shell\ticks
        }
    }
}

func shell/draw/chrome(shell: ptr<AER/SHELL>) {
    let whole: AER/RECT
    let taskbar: AER/RECT
    let titlebar: AER/RECT
    let info/hero: AER/RECT
    let cpu/card: AER/RECT
    let mem/card: AER/RECT
    let time/card: AER/RECT
    let footer/card: AER/RECT
    let cursor: AER/RECT
    let back: ptr<AER/BACK/BUFFER> = &shell\back as ptr<AER/BACK/BUFFER>
    let dirty: ptr<AER/DIRTY/LIST> = &shell\dirty as ptr<AER/DIRTY/LIST>
    let window/frame: ptr<AER/RECT> = &shell\main/window\frame as ptr<AER/RECT>
    let mem/pct: UInt32 = 0
    let mem/fill: UInt32 = 0
    let title/style: AER/TEXT/STYLE
    let hero/style: AER/TEXT/STYLE
    let body/style: AER/TEXT/STYLE
    let label/style: AER/TEXT/STYLE
    let metric/style: AER/TEXT/STYLE
    let warning/style: AER/TEXT/STYLE
    let date/style: AER/TEXT/STYLE
    let footer/style: AER/TEXT/STYLE

    text/style/set(&title/style as ptr<AER/TEXT/STYLE>, 0xFFF6FBFF, 0xFF8FB9E8, 0xFF000000, 46, 82, 2, 1)
    text/style/set(&hero/style as ptr<AER/TEXT/STYLE>, 0xFFEAF2FA, 0xFF89B4E8, 0xFF000000, 36, 72, 2, 1)
    text/style/set(&body/style as ptr<AER/TEXT/STYLE>, 0xFFBFD1E3, 0xFF89B4E8, 0xFF000000, 16, 42, 1, 1)
    text/style/set(&label/style as ptr<AER/TEXT/STYLE>, 0xFFEAF2FA, 0xFF89B4E8, 0xFF000000, 18, 52, 1, 1)
    text/style/set(&metric/style as ptr<AER/TEXT/STYLE>, 0xFFF7FBFF, 0xFF7ACB92, 0xFF000000, 28, 74, 2, 1)
    text/style/set(&warning/style as ptr<AER/TEXT/STYLE>, 0xFFE7A3A0, 0xFFE7A3A0, 0xFF000000, 20, 72, 2, 1)
    text/style/set(&date/style as ptr<AER/TEXT/STYLE>, 0xFF9FB3C7, 0xFF89B4E8, 0xFF000000, 10, 36, 1, 1)
    text/style/set(&footer/style as ptr<AER/TEXT/STYLE>, 0xFFD8E6F4, 0xFF89B4E8, 0xFF000000, 12, 36, 1, 1)

    rect/set(&whole as ptr<AER/RECT>, 0, 0, shell\back\width, shell\back\height)
    back/fill/rect(back, &whole as ptr<AER/RECT>, 0xFF0C1218)
    shell/fill(back, 0, 0, shell\back\width, 112, 0xFF111A24)
    shell/fill(back, 0, 112, shell\back\width, 2, 0xFF1A2633)

    rect/set(&taskbar as ptr<AER/RECT>, 0, shell\back\height - 52, shell\back\width, 52)
    back/fill/rect(back, &taskbar as ptr<AER/RECT>, 0xFF101820)
    shell/fill(back, 0, shell\back\height - 52, shell\back\width, 2, 0xFF233446)

    shell/draw/shadow(back, window/frame)
    back/fill/rect(back, window/frame, shell\main/window\material)
    shell/fill(back, window/frame\x + 8, window/frame\y + 8, window/frame\w - 16, window/frame\h - 16, 0xFF1B2734)

    rect/set(&titlebar as ptr<AER/RECT>, window/frame\x, window/frame\y, window/frame\w, 42)
    back/fill/rect(back, &titlebar as ptr<AER/RECT>, shell\main/window\accent)
    shell/fill(back, titlebar\x, titlebar\y + titlebar\h - 1, titlebar\w, 1, 0xFF5A87B9)
    shell/fill(back, titlebar\x + titlebar\w - 96, titlebar\y + 11, 16, 16, 0xFFDCE6F2)
    shell/fill(back, titlebar\x + titlebar\w - 68, titlebar\y + 11, 16, 16, 0xFFBFD0E3)
    shell/fill(back, titlebar\x + titlebar\w - 40, titlebar\y + 11, 16, 16, 0xFFE7A3A0)

    rect/set(&info/hero as ptr<AER/RECT>, window/frame\x + 28, window/frame\y + 66, window/frame\w - 56, 112)
    back/fill/rect(back, &info/hero as ptr<AER/RECT>, 0xFF213244)
    shell/fill(back, info/hero\x, info/hero\y, info/hero\w, 2, 0xFF3C6A9C)
    shell/fill(back, info/hero\x, info/hero\y + info/hero\h - 26, info/hero\w, 26, 0xFF182432)

    rect/set(&cpu/card as ptr<AER/RECT>, window/frame\x + 28, window/frame\y + 210, 248, 150)
    rect/set(&mem/card as ptr<AER/RECT>, cpu/card\x + 272, cpu/card\y, 248, 150)
    rect/set(&time/card as ptr<AER/RECT>, mem/card\x + 272, cpu/card\y, window/frame\w - 600, 150)
    back/fill/rect(back, &cpu/card as ptr<AER/RECT>, 0xFF1A2634)
    back/fill/rect(back, &mem/card as ptr<AER/RECT>, 0xFF1A2634)
    back/fill/rect(back, &time/card as ptr<AER/RECT>, 0xFF1A2634)
    shell/fill(back, cpu/card\x, cpu/card\y, cpu/card\w, 2, 0xFF3A6EA5)
    shell/fill(back, mem/card\x, mem/card\y, mem/card\w, 2, 0xFF4B8B63)
    shell/fill(back, time/card\x, time/card\y, time/card\w, 2, 0xFF6B86A7)

    rect/set(&footer/card as ptr<AER/RECT>, window/frame\x + 28, window/frame\y + 386, window/frame\w - 56, 154)
    back/fill/rect(back, &footer/card as ptr<AER/RECT>, 0xFF182331)
    shell/fill(back, footer/card\x, footer/card\y, footer/card\w, 2, 0xFF2B4663)

    text/draw/literal(back, titlebar\x + 18, titlebar\y + 7, 65, 69, 82, 69, 83, 67, 85, 69, 0, 0, 8, &title/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, info/hero\x + 22, info/hero\y + 14, 83, 89, 83, 84, 69, 77, 0, 0, 0, 0, 6, &hero/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, info/hero\x + 22, info/hero\y + 50, 85, 69, 70, 73, 32, 71, 79, 80, 0, 0, 8, &body/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, info/hero\x + 22, info/hero\y + 68, 82, 69, 65, 68, 89, 0, 0, 0, 0, 0, 5, &body/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, info/hero\x + 22, info/hero\y + 86, 76, 79, 67, 65, 76, 32, 82, 65, 77, 0, 9, &body/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, info/hero\x + info/hero\w - 214, info/hero\y + 16, 69, 83, 67, 32, 69, 83, 67, 0, 0, 0, 7, &hero/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, info/hero\x + info/hero\w - 214, info/hero\y + 54, 82, 69, 84, 85, 82, 78, 32, 70, 87, 0, 9, &body/style as ptr<AER/TEXT/STYLE>)

    text/draw/literal(back, cpu/card\x + 18, cpu/card\y + 16, 67, 80, 85, 32, 84, 69, 77, 80, 0, 0, 8, &label/style as ptr<AER/TEXT/STYLE>)
    if shell\sensor/cpu/online != 0 {
        text/draw/u32(back, cpu/card\x + 18, cpu/card\y + 56, shell\sensor/cpu/temp, 1, &metric/style as ptr<AER/TEXT/STYLE>)
    } else {
        text/draw/literal(back, cpu/card\x + 18, cpu/card\y + 58, 79, 70, 70, 76, 73, 78, 69, 0, 0, 0, 7, &warning/style as ptr<AER/TEXT/STYLE>)
    }
    text/draw/literal(back, cpu/card\x + 18, cpu/card\y + 118, 83, 69, 78, 83, 79, 82, 32, 78, 47, 65, 10, &date/style as ptr<AER/TEXT/STYLE>)

    text/draw/literal(back, mem/card\x + 18, mem/card\y + 16, 77, 69, 77, 79, 82, 89, 0, 0, 0, 0, 6, &label/style as ptr<AER/TEXT/STYLE>)
    if shell\memory/total/mb > 0 {
        mem/pct = (shell\memory/used/mb * 100) / shell\memory/total/mb
        mem/fill = (mem/pct * 200) / 100
    }
    shell/draw/progress(back, mem/card\x + 18, mem/card\y + 56, 208, 14, mem/fill, 0xFF7ACB92, 0xFF263748)
    text/draw/u32(back, mem/card\x + 18, mem/card\y + 84, shell\memory/used/mb, 1, &hero/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, mem/card\x + 104, mem/card\y + 92, 77, 66, 32, 47, 32, 0, 0, 0, 0, 0, 5, &body/style as ptr<AER/TEXT/STYLE>)
    text/draw/u32(back, mem/card\x + 162, mem/card\y + 92, shell\memory/total/mb, 1, &body/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, mem/card\x + 18, mem/card\y + 120, 85, 83, 69, 68, 0, 0, 0, 0, 0, 0, 4, &date/style as ptr<AER/TEXT/STYLE>)

    text/draw/literal(back, time/card\x + 18, time/card\y + 16, 82, 84, 67, 0, 0, 0, 0, 0, 0, 0, 3, &label/style as ptr<AER/TEXT/STYLE>)
    text/draw/two(back, time/card\x + 18, time/card\y + 54, shell\clock/hour as UInt32, &metric/style as ptr<AER/TEXT/STYLE>)
    text/draw/glyph(back, time/card\x + 88, time/card\y + 54, 58, &metric/style as ptr<AER/TEXT/STYLE>)
    text/draw/two(back, time/card\x + 108, time/card\y + 54, shell\clock/minute as UInt32, &metric/style as ptr<AER/TEXT/STYLE>)
    text/draw/glyph(back, time/card\x + 178, time/card\y + 54, 58, &metric/style as ptr<AER/TEXT/STYLE>)
    text/draw/two(back, time/card\x + 198, time/card\y + 54, shell\clock/second as UInt32, &metric/style as ptr<AER/TEXT/STYLE>)
    text/draw/four(back, time/card\x + 18, time/card\y + 118, shell\clock/year as UInt32, &date/style as ptr<AER/TEXT/STYLE>)
    text/draw/glyph(back, time/card\x + 66, time/card\y + 118, 47, &date/style as ptr<AER/TEXT/STYLE>)
    text/draw/two(back, time/card\x + 80, time/card\y + 118, shell\clock/month as UInt32, &date/style as ptr<AER/TEXT/STYLE>)
    text/draw/glyph(back, time/card\x + 108, time/card\y + 118, 47, &date/style as ptr<AER/TEXT/STYLE>)
    text/draw/two(back, time/card\x + 122, time/card\y + 118, shell\clock/day as UInt32, &date/style as ptr<AER/TEXT/STYLE>)

    text/draw/literal(back, footer/card\x + 20, footer/card\y + 18, 80, 73, 80, 69, 32, 82, 69, 65, 68, 89, 10, &label/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, footer/card\x + 20, footer/card\y + 52, 66, 79, 79, 84, 32, 71, 79, 80, 0, 0, 8, &footer/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, footer/card\x + 20, footer/card\y + 76, 70, 87, 32, 82, 69, 84, 85, 82, 78, 0, 9, &footer/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, footer/card\x + 20, footer/card\y + 100, 68, 73, 83, 75, 32, 48, 0, 0, 0, 0, 6, &footer/style as ptr<AER/TEXT/STYLE>)
    if shell\disk0\state == 3 {
        text/draw/literal(back, footer/card\x + 150, footer/card\y + 100, 79, 70, 70, 76, 73, 78, 69, 0, 0, 0, 7, &warning/style as ptr<AER/TEXT/STYLE>)
    } else {
        if shell\disk0\state == 2 {
            text/draw/literal(back, footer/card\x + 150, footer/card\y + 100, 80, 69, 78, 68, 73, 78, 71, 0, 0, 0, 7, &footer/style as ptr<AER/TEXT/STYLE>)
        } else {
            text/draw/literal(back, footer/card\x + 150, footer/card\y + 100, 73, 68, 76, 69, 0, 0, 0, 0, 0, 0, 4, &footer/style as ptr<AER/TEXT/STYLE>)
        }
    }
    text/draw/literal(back, footer/card\x + 20, footer/card\y + 124, 69, 83, 67, 32, 69, 83, 67, 0, 0, 0, 7, &footer/style as ptr<AER/TEXT/STYLE>)
    text/draw/literal(back, footer/card\x + 150, footer/card\y + 124, 82, 69, 84, 85, 82, 78, 32, 70, 87, 0, 9, &footer/style as ptr<AER/TEXT/STYLE>)

    if shell\pointer\visible != 0 {
        shell/fill(back, shell\pointer\x + 2, shell\pointer\y + 2, 10, 16, 0x55000000)
        rect/set(&cursor as ptr<AER/RECT>, shell\pointer\x, shell\pointer\y, 10, 16)
        back/fill/rect(back, &cursor as ptr<AER/RECT>, 0xFFF2F4F8)
    }

    dirty/reset(dirty)
    dirty/push(dirty, 0, 0, shell\back\width, shell\back\height)
}

func shell/render(shell: ptr<AER/SHELL>) {
    let back: ptr<AER/BACK/BUFFER> = &shell\back as ptr<AER/BACK/BUFFER>
    let dirty: ptr<AER/DIRTY/LIST> = &shell\dirty as ptr<AER/DIRTY/LIST>
    shell/draw/chrome(shell)
    back/flush/dirty(back, dirty)
}

func shell/prepare/firmware/return(shell: ptr<AER/SHELL>) : UInt64 {
    if shell == 0 {
        return EFI/NOT/READY
    }

    let sys/table: ptr<EFI/SYSTEM/TABLE> = cast<ptr<EFI/SYSTEM/TABLE>>(shell\sys/table)
    let dirty: ptr<AER/DIRTY/LIST> = &shell\dirty as ptr<AER/DIRTY/LIST>
    let back: ptr<AER/BACK/BUFFER> = &shell\back as ptr<AER/BACK/BUFFER>

    shell\pointer\visible = 0
    shell/render(shell)
    dirty/reset(dirty)
    dirty/push(dirty, 0, 0, shell\back\width, shell\back\height)
    back/flush/dirty(back, dirty)
    uefi/disable/watchdog(sys/table)
    return uefi/quiesce/input(sys/table)
}

func shell/watchdog/tick(shell: ptr<AER/SHELL>) {
    if shell\disk0\state == 1 && shell\ticks >= 64 {
        shell\disk0\state = 2
        shell\disk0\pending/since = shell\ticks * 10
    }
    if shell\disk0\state == 2 {
        let elapsed: UInt64 = (shell\ticks * 10) - shell\disk0\pending/since
        if elapsed > shell\disk0\timeout/ms {
            shell\disk0\state = 3
            debug/stage(90)
        }
    }
}

func shell/pointer/tick(shell: ptr<AER/SHELL>) {
    if (shell\ticks & 7) == 0 {
        if shell\pointer\x + 12 < shell\back\width {
            shell\pointer\x = shell\pointer\x + 12
        } else {
            shell\pointer\x = 24
        }
    }
}

func shell/bootstrap(shell: ptr<AER/SHELL>, sys/table: ptr<EFI/SYSTEM/TABLE>) : Bool {
    shell\sys/table = cast<UInt64>(sys/table)
    shell\exit/armed/after = 300
    uefi/reset/input(sys/table)
    debug/stage(0x41)
    shell\gop = uefi/locate/gop(sys/table)
    if shell\gop == 0 {
        debug/stage(0x42)
        return false
    }
    debug/stage(0x43)
    if buffer/init(&shell\back as ptr<AER/BACK/BUFFER>, shell\gop, sys/table) == 0 {
        debug/stage(0x44)
        return false
    }
    debug/stage(0x45)
    shell/layout/init(shell)
    shell/update/telemetry(shell)
    debug/stage(0x46)
    return true
}

func shell/run(shell: ptr<AER/SHELL>) : UInt64 {
    let sys/table: ptr<EFI/SYSTEM/TABLE> = cast<ptr<EFI/SYSTEM/TABLE>>(shell\sys/table)

    loop {
        shell/poll/input(shell)
        if shell\exit/requested != 0 {
            return EFI/SUCCESS
        }
        shell/pointer/tick(shell)
        shell/watchdog/tick(shell)
        shell/update/telemetry(shell)
        shell/render(shell)
        uefi/stall(sys/table, 10000)
        shell\ticks = shell\ticks + 1
    }
    return EFI/SUCCESS
}
