const DEC/TEN: UInt32 = 10
const DEC/HUNDRED: UInt32 = 100
const DEC/THOUSAND: UInt32 = 1000
const ALPHA/MAX: UInt32 = 255
const GLYPH/WIDTH: UInt32 = 10
const GLYPH/HEIGHT: UInt32 = 12
const GLYPH/ADVANCE: UInt32 = 11

struct AER/POINTER/STATE {
    x: UInt32
    y: UInt32
    visible: UInt64
}

struct AER/DRIVE/STATE {
    state: UInt64
    pending/since: UInt64
    timeout/ms: UInt64
}

struct AER/WINDOW {
    frame: AER/RECT
    accent: UInt32
    material: UInt32
}

struct AER/TEXT/STYLE {
    color: UInt32
    glow/color: UInt32
    shadow/color: UInt32
    glow/alpha: UInt32
    shadow/alpha: UInt32
    scale: UInt32
    tracking: UInt32
}

struct AER/NEXUS/PROTOCOL {
    revision: UInt64
    create/window: UInt64
    draw/text: UInt64
    draw/rect: UInt64
    show/message: UInt64
}

struct AER/SHELL {
    sys/table: UInt64
    gop: UInt64
    ticks: UInt64
    exit/requested: UInt64
    last/esc/ticks: UInt64
    exit/armed/after: UInt64
    memory/total/mb: UInt32
    memory/used/mb: UInt32
    clock/year: UInt16
    clock/month: UInt8
    clock/day: UInt8
    clock/hour: UInt8
    clock/minute: UInt8
    clock/second: UInt8
    sensor/cpu/temp: UInt32
    sensor/cpu/online: UInt64
    back: AER/BACK/BUFFER
    dirty: AER/DIRTY/LIST
    pointer: AER/POINTER/STATE
    main/window: AER/WINDOW
    disk0: AER/DRIVE/STATE
    nexus: AER/NEXUS/PROTOCOL
}

func shell/fill(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, w: UInt32, h: UInt32, color: UInt32) {
    let rect: AER/RECT
    rect/set(&rect as ptr<AER/RECT>, x, y, w, h)
    back/fill/rect(back, &rect as ptr<AER/RECT>, color)
}

// (在 shell/fill 函数定义的紧接着下方插入)
func shell/draw/progress(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, w: UInt32, h: UInt32, fill: UInt32, fg: UInt32, bg: UInt32) {
    // 绘制底色
    shell/fill(back, x, y, w, h, bg)
    // 绘制进度高亮色
    if fill > 0 {
        let fw: UInt32 = fill
        if fw > w { 
            fw = w 
        }
        shell/fill(back, x, y, fw, h, fg)
    }
}

func shell/draw/shadow(back: ptr<AER/BACK/BUFFER>, frame: ptr<AER/RECT>) {
    shell/fill(back, frame\x + 8, frame\y + frame\h, frame\w, 10, 0x33000000)
    shell/fill(back, frame\x + frame\w, frame\y + 8, 10, frame\h, 0x22000000)
}

func text/style/set(style: ptr<AER/TEXT/STYLE>, color: UInt32, glow/color: UInt32, shadow/color: UInt32, glow/alpha: UInt32, shadow/alpha: UInt32, scale: UInt32, tracking: UInt32) {
    style\color = color
    style\glow/color = glow/color
    style\shadow/color = shadow/color
    style\glow/alpha = glow/alpha
    style\shadow/alpha = shadow/alpha
    style\scale = scale
    style\tracking = tracking
}

func text/advance(style: ptr<AER/TEXT/STYLE>) : UInt32 {
    return (GLYPH/ADVANCE * style\scale) + style\tracking
}

func alpha/modulate(alpha: UInt32, factor: UInt32) : UInt32 {
    if alpha == 0 || factor == 0 {
        return 0
    }
    if factor >= ALPHA/MAX {
        return alpha
    }
    let numer: UInt64 = ((alpha as UInt64) * (factor as UInt64)) + 127
    let alpha/max/u64: UInt64 = ALPHA/MAX as UInt64
    return cast<UInt32>(numer / alpha/max/u64)
}

